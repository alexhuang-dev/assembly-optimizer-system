# Assembly Optimizer environment example

# Optional LLM specialist layer.
# Leave disabled for deterministic offline operation.
ASSEMBLY_LLM_ENABLED=false
ASSEMBLY_LLM_PROVIDER=disabled
ASSEMBLY_LLM_MODEL=
ASSEMBLY_LLM_API_BASE_URL=https://api.openai.com/v1
ASSEMBLY_LLM_API_KEY=
ASSEMBLY_LLM_TEMPERATURE=0.1
ASSEMBLY_LLM_MAX_TOKENS=700
ASSEMBLY_LLM_TIMEOUT_SECONDS=60

# Optional JSON object for provider-specific headers.
# Example: {"X-Provider-Trace":"local-demo"}
ASSEMBLY_LLM_EXTRA_HEADERS={}
